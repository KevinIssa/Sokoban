# g++ -std=c++20 -Wall -Wpedantic -Werror main.cpp sokoban.cpp controller.cpp -o soko -lfltk -lfltk_images && ./soko

# g++ -std=c++11 main.cpp sokoban.cpp controller.cpp -o soko -lfltk -lfltk_images && ./soko

soko : main.o sokoban.o controller.o
	g++ -o soko main.o sokoban.o controller.o -lfltk -lfltk_images

main.o : main.cpp
	g++ -c -std=c++11 main.cpp -lfltk -lfltk_images

sokoban.o : sokoban.cpp
	g++ -c -std=c++11 sokoban.cpp -lfltk -lfltk_images

controller.o : controller.cpp
	g++ -c -std=c++11 controller.cpp -lfltk -lfltk_images 




CXXFLAGS += $(shell fltk-config --cxxflags | sed 's/-I/-isystem/g')
LDLIBS   += $(shell fltk-config --ldflags)

CXXFLAGS += -std='c++20' -Wall
LDLIBS   += -lfltk -lfltk_images


SOURCES = $(wildcard *.cpp)
OBJECTS = $(patsubst %.cpp, %.o, ${SOURCES})

soko : ${OBJECTS}
    ${CXX} ${LDFLAGS} $^ -o $@ ${LOADLIBES} ${LDLIBS}


main: ${OBJECTS}
    ${CXX} ${LDFLAGS} $^ -o $@ ${LOADLIBES} ${LDLIBS}

sokoban: ${OBJECTS}
    ${CXX} ${LDFLAGS} $^ -o $@ ${LOADLIBES} ${LDLIBS}

controller: ${OBJECTS}
    ${CXX} ${LDFLAGS} $^ -o $@ ${LOADLIBES} ${LDLIBS}



.PHONY: clean
clean:
    -rm *.o

# make mrclean supprime les fichiers objets et les exécutables
.PHONY: mrclean
mrclean: clean
    -rm soko main sokoban controller


